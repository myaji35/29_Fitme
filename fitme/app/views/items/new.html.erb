<div class="form-page">
  <h1>새 아이템 추가</h1>

  <%= form_with model: @item, local: true, data: { controller: "item-analyzer" } do |f| %>
    <% if @item.errors.any? %>
      <div class="errors">
        <h3><%= pluralize(@item.errors.count, "error") %> prohibited this item from being saved:</h3>
        <ul>
          <% @item.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :image, "옷 사진" %>
      <%= f.file_field :image, accept: "image/*", required: true,
          data: {
            item_analyzer_target: "fileInput",
            action: "change->item-analyzer#analyzeImage"
          } %>
      <small>사진을 업로드하면 AI가 자동으로 배경을 제거하고 분석합니다.</small>
      <div class="ai-status" data-item-analyzer-target="status" style="display: none; margin-top: 8px; font-weight: 600;"></div>
    </div>

    <div class="form-group">
      <%= f.label :category, "카테고리" %>
      <%= f.select :category, options_for_select([["상의", "top"], ["하의", "bottom"], ["아우터", "outer"], ["신발", "shoes"]]),
          { prompt: "선택하세요" },
          { required: true, data: { item_analyzer_target: "category" } } %>
    </div>

    <div class="form-group">
      <%= f.label :color, "색상 (선택사항)" %>
      <%= f.text_field :color, placeholder: "예: 파란색, 검정색",
          data: { item_analyzer_target: "color" } %>
    </div>

    <div class="form-group">
      <%= f.label :season, "계절 (선택사항)" %>
      <%= f.select :season, options_for_select([["봄", "spring"], ["여름", "summer"], ["가을", "fall"], ["겨울", "winter"]]),
          { prompt: "선택하세요" },
          { data: { item_analyzer_target: "season" } } %>
    </div>

    <div class="form-actions">
      <%= f.submit "추가하기", class: "btn btn-primary" %>
      <%= link_to "취소", items_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<style>
.ai-status {
  padding: 12px 16px;
  background: #F0F9F8;
  border-radius: 8px;
  font-size: 0.9rem;
  border-left: 4px solid #5BB9AE;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.auto-filled {
  animation: highlight 2s ease;
  border-color: #4ECDC4 !important;
}

@keyframes highlight {
  0%, 100% {
    background-color: transparent;
  }
  50% {
    background-color: #E8F5F3;
  }
}
</style>
